# Base URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:8000

# Set to "true" to use local mock data instead of calling the real API.
# Useful for development/demo without a running backend.
# Default: false (real API is used).
# VITE_USE_MOCK=false

# Set to "true" if the backend sends monetary amounts in cents instead of euros
# (e.g. unitPrice: 1500 means 15 €). Default: false (prices are in euros).
# VITE_PRICES_IN_CENTS=false
