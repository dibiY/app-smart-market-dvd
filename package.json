{
  "name": "app-smart-market-dvd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:test": "tsc -b && vite build --mode test",
    "build:recette": "tsc -b && vite build --mode recette",
    "build:prod": "tsc -b && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "docker:local": "docker compose -f docker-compose.yml -f docker-compose.local.yml up --build",
    "docker:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml up --build",
    "docker:recette": "docker compose -f docker-compose.yml -f docker-compose.recette.yml up --build",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build",
    "docker:build:test": "docker compose -f docker-compose.yml -f docker-compose.test.yml build",
    "docker:build:recette": "docker compose -f docker-compose.yml -f docker-compose.recette.yml build",
    "docker:build:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml build",
    "docker:down": "docker compose down --remove-orphans"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.4",
    "vitest": "^3.1.1"
  }
}
